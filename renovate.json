{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>konflux-ci/mintmaker-presets:refresh-rpm-lockfiles",
    "github>konflux-ci/mintmaker-presets:cve-automerge-high"
  ],
  "rpm-lockfile": {
    "lockFileMaintenance": {
      "enabled": false
    }
  },
  "packageRules": [
    {
      "description": "Disable go updates for .konflux directory",
      "matchFileNames": [".konflux/**"],
      "enabled": false
    },
    {
      "description": "Group go non-major; CVE automerge via cve-automerge-high preset",
      "matchBaseBranches": ["/^release.*/", "main"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all go non-major dependencies"
    },
    {
      "matchBaseBranches": ["main"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": "all go major dependencies"
    },
    {
      "description": "Group dockerfile non-major; RPM locks refresh via refresh-rpm-lockfiles preset",
      "matchBaseBranches": ["/^release.*/", "main"],
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all dockerfile non-major dependencies"
    },
    {
      "matchBaseBranches": ["main"],
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "groupName": "all dockerfile major dependencies"
    }
  ],
  "autoApprove": true,
  "tekton": {
    "managerFilePatterns": ["/\\.tekton/.*\\.yaml$/"],
    "automerge": true,
    "automergeStrategy": "rebase",
    "automergeType": "pr",
    "enabled": true,
    "platformAutomerge": true
  }
}
