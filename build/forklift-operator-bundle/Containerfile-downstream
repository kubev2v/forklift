ARG EVENT_TITLE

ARG MTV_VERSION
ARG RELEASE
ARG CHANNEL
ARG DEFAULT_CHANNEL
ARG REGISTRY
ARG OCP_VERSIONS

ARG API_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-api-rhel9@sha256:36ff67b6a3fc7890b7eedbbe77c1ebc2089f455206338712d45c31c6f378324d"

ARG CONTROLLER_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-controller-rhel9@sha256:540e642e42091670fc364ae294dedf21d7299196f4c2c902e4e8c1b5efa6e78b"

ARG MUST_GATHER_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-must-gather-rhel8@sha256:0e7df97a01a50cafd5bc04800618f9565bbdced34652f1328304e02562726cc7"

ARG OPENSTACK_POPULATOR_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-openstack-populator-rhel9@sha256:186722b5c25fd696ceaa8de7fa41b90812daf08fd755762bb2d54c207424fc0b"

ARG OPERATOR_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-rhel9-operator@sha256:b209c1d96b160c623ff9365081034417a9d02053b98abb8a8114246684d715df"

ARG OVA_PROVIDER_SERVER_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-ova-provider-server-rhel9@sha256:bf03648601def138dec439d61cd0c86edcc965a9498261641495a82d7549e10f"

ARG OVA_PROXY_IMAGE="registry.redhat.io/migration-toolkit-virtualization/mtv-ova-proxy-rhel9@sha256:ed81e5bd7b06b3fc9cce8f9eab2454078d2aa03fa010b3406afe90fc95b8e7bf"

