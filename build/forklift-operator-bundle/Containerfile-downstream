ARG EVENT_TITLE

ARG MTV_VERSION
ARG RELEASE
ARG CHANNEL
ARG DEFAULT_CHANNEL
ARG REGISTRY
ARG OCP_VERSIONS

ARG API_IMAGE="registry.redhat.io/mtv-candidate/mtv-api-rhel9@sha256:506c3c63fec259faf8452fc8538aa67da1ce69df9c4ea2e0bf1889a649522e20"

ARG CONTROLLER_IMAGE="registry.redhat.io/mtv-candidate/mtv-controller-rhel9@sha256:dc3a570e89c76b9662b5d36a408a264c87c5c4fbe88592707bb18594bdd60982"

ARG MUST_GATHER_IMAGE="registry.redhat.io/mtv-candidate/mtv-must-gather-rhel8@sha256:6029dbf4b8d152ecfdc2326a213c702226126e11a9c9eef387a284c8c192aa26"

ARG OPENSTACK_POPULATOR_IMAGE="registry.redhat.io/mtv-candidate/mtv-openstack-populator-rhel9@sha256:f2d6838f9655ca2e3b0814e8ea1eba02bda54ff6b52fd5a28d6db229a8a65539"

ARG OPERATOR_IMAGE="registry.redhat.io/mtv-candidate/mtv-rhel9-operator@sha256:a1dd545f4fcab0add22c798fc6be5b072149be9f7b9ccec5e328611e72115b1e"

