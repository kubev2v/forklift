# Build stage
FROM registry.access.redhat.com/ubi9/go-toolset:1.25.7-1772728670 AS builder

USER 0
WORKDIR /app
COPY --chown=1001:0 ./ ./
ENV GOFLAGS="-mod=vendor"
ENV GOCACHE=/go-build/cache

# Build all platform binaries for download
WORKDIR /app/cmd/kubectl-mtv
RUN --mount=type=cache,target=${GOCACHE},uid=1001 make build-all

# Build a native binary for the MCP server running inside the container
RUN --mount=type=cache,target=${GOCACHE},uid=1001 go build -buildvcs=false -ldflags="-w -s" -o mcp-bin/kubectl-mtv

# Nginx + MCP server stage
FROM registry.access.redhat.com/ubi9/nginx-126:1-1772411898

# Copy cross-compiled binaries for all platforms (linux, darwin, windows)
COPY --from=builder /app/cmd/kubectl-mtv/bin /opt/app-root/src/

# Copy native binary for MCP server runtime
COPY --from=builder --chmod=755 /app/cmd/kubectl-mtv/mcp-bin/kubectl-mtv /usr/local/bin/kubectl-mtv

# Nginx server block for CLI static file serving
COPY build/forklift-cli-download/nginx.conf /opt/app-root/etc/nginx.d/nginx.conf

ENV MCP_OUTPUT_FORMAT="markdown" \
    MCP_MAX_RESPONSE_CHARS="0" \
    MCP_READ_ONLY="false" \
    MCP_VERBOSE="2" \
    MCP_KUBE_SERVER="" \
    MCP_KUBE_INSECURE=""

EXPOSE 8443 8081

ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

LABEL \
        com.redhat.component="mtv-cli-download-container" \
        name="migration-toolkit-virtualization/mtv-cli-download-rhel9" \
        license="Apache License 2.0" \
        io.k8s.display-name="Migration Toolkit for Virtualization" \
        io.k8s.description="Migration Toolkit for Virtualization - CLI Download and MCP Server" \
        io.openshift.tags="migration,mtv,forklift,cli,mcp" \
        summary="Migration Toolkit for Virtualization - CLI Download and MCP Server" \
        description="Migration Toolkit for Virtualization - CLI Download and MCP Server" \
        vendor="Red Hat, Inc." \
        maintainer="Migration Toolkit for Virtualization Team <migtoolkit-virt@redhat.com>" \
        org.opencontainers.image.revision="$GIT_COMMIT" \
        org.opencontainers.image.created="$BUILD_DATE" \
        org.opencontainers.image.source="https://github.com/kubev2v/forklift"
