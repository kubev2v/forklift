		--source-vmdk="[eco-iscsi-ds2] vm-1/vm-1.vmdk" \
		--target-pvc=test-cli \
		--target-namespace=default \
		--storage-vendor=ontap \
		--secret-ref=populator-secret \
		--kubeconfig=$$KUBECONFIG

