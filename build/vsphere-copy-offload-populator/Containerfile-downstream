FROM registry.redhat.io/ubi9/go-toolset:1.25.9-1777043046 AS builder
COPY --chown=1001:0 . /src
WORKDIR /src/cmd/vsphere-copy-offload-populator

ENV GOFLAGS="-mod=vendor -tags=strictfipsruntime"
ENV GOEXPERIMENT=strictfipsruntime

RUN GOOS=linux GOARCH=amd64 make build test

RUN make vmkfstools-wrapper

FROM registry.redhat.io/ubi9-minimal:9.7-1776833838

COPY --from=builder /src/cmd/vsphere-copy-offload-populator/bin/vsphere-copy-offload-populator \
    /bin/vsphere-copy-offload-populator

COPY --from=builder /src/cmd/vsphere-copy-offload-populator/bin/vib-installer \
    /bin/vib-installer

COPY --from=builder /src/cmd/vsphere-copy-offload-populator/vmkfstools-wrapper/vmkfstools-wrapper.vib \
    /bin/vmkfstools-wrapper.vib

ENTRYPOINT ["/bin/vsphere-copy-offload-populator"]

ARG MTV_VERSION
ARG REGISTRY
ARG REVISION
ARG CPE

LABEL \
    com.redhat.component="mtv-vsphere-copy-offload-populator-container" \
    name="${REGISTRY}/mtv-vsphere-copy-offload-populator-rhel9" \
    license="Apache License 2.0" \
    io.k8s.display-name="Migration Toolkit for Virtualization" \
    io.k8s.description="Migration Toolkit for Virtualization - vSphere XCOPY Volume Populator" \
    io.openshift.tags="migration,mtv,forklift" \
    summary="Migration Toolkit for Virtualization - vSphere XCOPY Volume Populator" \
    description="Migration Toolkit for Virtualization - vSphere XCOPY Volume Populator" \
    vendor="Red Hat, Inc." \
    maintainer="Migration Toolkit for Virtualization Team <migtoolkit-virt@redhat.com>" \
    version="$MTV_VERSION" \
    cpe="cpe:/a:redhat:migration_toolkit_virtualization:${CPE}::el9" \
    revision="$REVISION"
